{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Quartz": "Information"
    }
  },

  "Database": {
    "_comment": "Override via env var TRADINGBOT__Database__ConnectionString in production. The default below uses Docker service name 'postgres' so docker-compose works out of the box.",
    "ConnectionString": "Host=localhost;Port=5432;Database=trading_recommender;Username=postgres;Password="
  },

  "Schedule": {
    "MarketScanCron": "0 9 * * MON-FRI",
    "DigestCron": "0 16 * * MON-FRI"
  },

  "TradingSettings": {
    "GoApi": {
      "BaseUrl": "https://api.goapi.io/v1/stock",
      "ApiKey": "",
      "TimeoutSeconds": 15,
      "RetryCount": 5
    },
    "Telegram": {
      "BotToken": "",
      "ChatId": "",
      "ParseMode": "Markdown"
    },
    "Schedule": {
      "MarketScanCron": "0 9 * * MON-FRI",
      "DigestCron": "0 16 * * MON-FRI",
      "TimeZoneId": "Asia/Jakarta"
    },
    "ForeignFlow": {
      "BuyThreshold": 2.0,
      "SellThreshold": 2.0,
      "VolumeFloor": 5000000000,
      "VolumeCeiling": 15000000000
    },
    "Portfolio": {
      "TrackPerformance": true,
      "Stocks": [
        { "Symbol": "BBCA", "Name": "Bank Central Asia",        "PositionQty": 100 },
        { "Symbol": "TLKM", "Name": "Telekomunikasi Indonesia", "PositionQty": 200 },
        { "Symbol": "ASII", "Name": "Astra International",      "PositionQty": 150 }
      ]
    },
    "Notification": {
      "QuietHoursStart": "17:00:00",
      "QuietHoursEnd": "08:00:00",
      "MaxItemsPerDigest": 20,
      "OnlyActionable": true
    }
  }
}